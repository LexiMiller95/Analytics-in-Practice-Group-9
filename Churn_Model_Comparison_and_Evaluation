    {
      "cell_type": "code",
      "source": [
        "# 🧹 CLEANING STEP 1: Mixed Format Date Parsing (Data Type Corrections)\n",
        "\n",
        "# Create a working copy for cleaning\n",
        "df_clean = df_raw.copy()\n",
        "\n",
        "def parse_mixed_dates(series):\n",
        "    result = pd.Series(index=series.index, dtype='datetime64[ns]')\n",
        "\n",
        "    # Handle slash format: M/D/YYYY\n",
        "    mask_slash = series.str.contains('/', na=False)\n",
        "    result[mask_slash] = pd.to_datetime(series[mask_slash], format='%m/%d/%Y', errors='coerce')\n",
        "\n",
        "    # Handle dash format: DD-MM-YYYY\n",
        "    mask_dash  = series.str.contains('-', na=False)\n",
        "    result[mask_dash]  = pd.to_datetime(series[mask_dash], format='%d-%m-%Y', errors='coerce')\n",
        "\n",
        "    return result\n",
        "\n",
        "# Apply custom parsing to the three date columns\n",
        "date_cols = ['signup_date', 'last_purchase_date', 'order_date']\n",
        "for col in date_cols:\n",
        "    df_clean[col] = parse_mixed_dates(df_clean[col])\n",
        "\n",
        "# Verify the transformation\n",
        "print(\"--- Data Types After Correction ---\")\n",
        "print(df_clean[date_cols].dtypes)\n",
        "print(f\"\\nMissing dates after custom parsing:\\n{df_clean[date_cols].isnull().sum()}\")\n",
        "\n",
        "\n",
        "print(f\"Total duplicate records: {df_clean.duplicated().sum()}\")\n",
        "print(f\"Total duplicate Customer IDs: {df_clean['customer_id'].duplicated().sum()}\")"
      ],
