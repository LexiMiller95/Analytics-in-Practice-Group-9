        "# 🧹 CLEANING STEP 4: Outlier Treatment (Winsorization)\n",
        "\n",
        "print(f\"Row count before outlier treatment: {len(df_clean)}\")\n",
        "\n",
        "# Focus on continuous numerical columns prone to extreme business variance\n",
        "num_cols = ['unit_price', 'quantity', 'purchase_frequency']\n",
        "\n",
        "print(\"\\n--- Before Outlier Treatment (Max Values) ---\")\n",
